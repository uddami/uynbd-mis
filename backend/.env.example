# Google Sheets API Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=8h

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Google Drive (for file links)
GOOGLE_DRIVE_FOLDER_ID=

# Admin Bootstrap (first-time setup)
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@uynbd.org
BOOTSTRAP_SUPER_ADMIN_PASSWORD=ChangeThisImmediately123!
